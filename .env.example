# Public (browser) env vars
# Optional. Leave empty to use same-origin `/api/*`.
NEXT_PUBLIC_API_BASE=
# Optional but recommended in production. Used for sitemap/robots/canonical URLs.
# Examples:
# NEXT_PUBLIC_SITE_URL=https://www.allremotes.com
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=

# Address autocomplete (Checkout)
NEXT_PUBLIC_GEOAPIFY_API_KEY=


MONGODB_DB=allremotes
# Set to 1 only when you want to ignore MongoDB and use local JSON data for UI testing.
MONGODB_DISABLED=0
# Last-resort for non-Atlas/self-signed TLS setups. Prefer fixing your cluster/URI instead.
MONGODB_TLS_INSECURE=0

# Admin-only helpers (server)
# By default, these are enabled in development and disabled in production.
# Force-enable in production (dangerous): set to 1.
ALLOW_ADMIN_RESET=0
ALLOW_ADMIN_ORDERS=0

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Fraud Detection Configuration
FRAUD_DETECTION_ENABLED=true
HIGH_VALUE_THRESHOLD=500
MAX_ORDERS_PER_IP=5
MAX_ORDERS_PER_ADDRESS=3

# Starshipit Shipping Configuration
STARSHIPIT_API_KEY=your_starshipit_api_key_here
STARSHIPIT_SUBSCRIPTION_KEY=your_starshipit_subscription_key_here
STARSHIPIT_ORIGIN_ADDRESS=Your Warehouse Address
STARSHIPIT_ORIGIN_SUBURB=Your Suburb
STARSHIPIT_ORIGIN_CITY=Your City
STARSHIPIT_ORIGIN_POSTCODE=Your Postcode
STARSHIPIT_ORIGIN_COUNTRY=AU

# OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
NEXT_PUBLIC_APPLE_SERVICE_ID=YOUR_APPLE_SERVICE_ID_HERE
APPLE_TEAM_ID=YOUR_TEAM_ID_HERE
APPLE_KEY_ID=YOUR_KEY_ID_HERE
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_CONTENTS_HERE
-----END PRIVATE KEY-----"

# AWS S3 Configuration
S3_BUCKET_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

MONGODB_URI=mongodb+srv://intern:Z9axiy75zxpxwekF@allremotes.9jdilke.mongodb.net/
NEXT_PUBLIC_GEOAPIFY_API_KEY=d13af7b0331e477c978995e93c275470
