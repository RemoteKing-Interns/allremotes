# Public (browser) env vars
# Optional. Leave empty to use same-origin `/api/*`.
NEXT_PUBLIC_API_BASE=
# Optional but recommended in production. Used for sitemap/robots/canonical URLs.
# Examples:
# NEXT_PUBLIC_SITE_URL=https://www.allremotes.com
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=

# Address autocomplete (Checkout)
NEXT_PUBLIC_GEOAPIFY_API_KEY=

# Server-only env vars (API routes)
# Required for persisting products/content on Vercel.
MONGODB_URI=
# Optional; if omitted, we use the db name from the URI (if present), else `allremotes`.
MONGODB_DB=allremotes
# Set to 1 only when you want to ignore MongoDB and use local JSON data for UI testing.
MONGODB_DISABLED=0
# Last-resort for non-Atlas/self-signed TLS setups. Prefer fixing your cluster/URI instead.
MONGODB_TLS_INSECURE=0

# Admin-only helpers (server)
# By default, these are enabled in development and disabled in production.
# Force-enable in production (dangerous): set to 1.
ALLOW_ADMIN_RESET=0
ALLOW_ADMIN_ORDERS=0
